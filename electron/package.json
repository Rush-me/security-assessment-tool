{
  "name": "security-risk-assessment-tool",
  "productName": "ISRA 2.0",
  "version": "2.0.0",
  "description": "Thales Security Risk Assessment Tool (ISRA) - Desktop Application",
  "homepage": "https://www.thalesgroup.com",
  "main": "main.js",
  "author": "Thales Group",
  "license": "MIT",
  
  "scripts": {
    "dev": "node scripts/build.js --dev",
    "build": "node scripts/build.js --prod",
    "pack": "electron-builder --dir",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac",
    "dist:all": "electron-builder --win --linux --mac",
    "download-jre": "node scripts/download-jre.js",
    "postinstall": "electron-builder install-app-deps",
    "electron:dev": "electron ."
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "decompress": "^4.2.1",
    "decompress-targz": "^4.1.1",
    "decompress-unzip": "^4.0.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "extends": "./builder-config.yml"
  }
}